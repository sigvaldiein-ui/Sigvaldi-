    <script>
    function handleDrop(e){{
      e.preventDefault();
      var f=e.dataTransfer.files[0];
      if(f) handleFile(f);
    }}
    function handleFile(file){{
      if(!file||!file.name.toLowerCase().endsWith('.pdf')){{
        showStat('Villa: aðeins PDF skjöl eru samþykkt.','#2a0f0f','#f87171');return;
      }}
      if(file.size>10485760){{
        showStat('Villa: skjal of stórt (hámark 10MB).','#2a0f0f','#f87171');return;
      }}
      showStat('Greini skjal...','#1a1a2e','#818cf8');
      var fd=new FormData();
      fd.append('file',file);
      fetch('/api/analyze-document',{{method:'POST',body:fd}})
        .then(function(r){{return r.json();}})
        .then(function(d){{
          if(!d.found){{
            showStat('Þessar upplýsingar fundust ekki í skjalinu.','#1a1a0f','#fbbf24');
            document.getElementById('citations-container').innerHTML='<p style="color:#555;font-size:.85rem;margin-top:.5rem">Engin tilvísun fannst í innsendu skjali.</p>';
            return;
          }}
          showStat('Greining lokið — '+d.sidur+' síður.','#0f2a1e','#34d399');
          renderCits(d.citations);
        }})
        .catch(function(){{showStat('Tenging við þjón mistókst.','#2a0f0f','#f87171');}});
    }}
    function showStat(msg,bg,col){{
      var el=document.getElementById('analysis-status');
      el.style.display='block';el.style.background=bg;el.style.color=col;el.textContent=msg;
    }}
    function renderCits(cits){{
      var c=document.getElementById('citations-container');
      if(!cits||!cits.length){{c.innerHTML='';return;}}
      var h='<h3 class="citations-heading">Heimildir í skjali</h3>';
      for(var i=0;i<cits.length;i++){{
        var ci=cits[i];
        h+='<div class="citation-card"><div class="citation-meta"><span class="page-badge">Bls. '+ci.page+'</span>';
        if(ci.section) h+='<span class="cite-sec">'+ci.section+'</span>';
        h+='</div><p class="citation-excerpt">'+ci.excerpt+'</p></div>';
      }}
      c.innerHTML=h;
    }}
