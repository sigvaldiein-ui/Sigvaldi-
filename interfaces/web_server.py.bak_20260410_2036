    <!-- Sprint 25f: Intake v7 JS -->
    <script>
    (function(){{
    var _t="a",_f=null,_busy=false;

    // E20: Approved copy — no raw errors in UI
    var _msg={{
      no_file:    "Vinsamlegast veldu skjal áður en þú heldur áfram.",
      empty_prompt:"Vinsamlegast skrifaðu fyrirspurn áður en þú sendir inn.",
      unsupported:"Þessi skráartegund er ekki studd. Settu inn PDF, Word- eða Excel-skjal.",
      empty_file: "Skjalið virðist vera tómt. Athugaðu skrána og reyndu aftur.",
      too_large:  "Skjalið er of stórt (hámark 20 MB). Vinsamlegast veldu minni skrá.",
      magic_bytes:"Skjalið er ekki lesanlegt. Reyndu aftur með annað eintak.",
      parse_fail: "Skjalið er ekki lesanlegt. Prófaðu að vista skjalið aftur.",
      no_text:    "Skjalið inniheldur eingöngu myndir og er ekki lesanlegt.",
      server:     "Eitthvað fór úr lag á þjóninum. Reyndu aftur eftir smástund.",
      timeout:    "Tengingin rauf á meðan skjalið var greint. Reyndu aftur.",
      long_load:  "Greining er að taka lengri tíma en vanalegt. Reyndu aftur.",
      generic:    "Eitthvað fór úr lag. Reyndu aftur.",
      multi_file: "Aðeins er hægt að greina eina skrá í einu. Fyrsta skráin var valin.",
      folder_drop:"Ekki er hægt að hlaða upp möppum. Vinsamlegast veldu eina skrá.",
      navigate:   "Ef þú ferð af síðunni mun greiningin tapast. Viltu halda áfram?"
    }};

    // E19: Clear all state before retry
    function v7Reset(){{
      _f=null; _busy=false;
      var sbtn=document.getElementById("v7-sbtn");
      if(sbtn){{sbtn.disabled=false;}}
      var fname=document.getElementById("v7-fname");
      if(fname)fname.textContent="";
      var fi=document.getElementById("v7-fi");
      if(fi)fi.value="";
      document.getElementById("v7-status").style.display="none";
      document.getElementById("v7-results").innerHTML="";
      v7UpdateBtn();
    }}

    // E1: Disable Greina until file or text present
    function v7UpdateBtn(){{
      var sbtn=document.getElementById("v7-sbtn");
      if(!sbtn)return;
      var txt=(document.getElementById("v7-txt")||{{}}).value||"";
      var hasContent=(_f!==null||txt.trim().length>0);
      sbtn.disabled=!hasContent;
      sbtn.style.opacity=hasContent?"1":"0.5";
      sbtn.style.cursor=hasContent?"pointer":"not-allowed";
    }}

    function v7SetTier(t){{
      _t=t;var isB=t==="b";
      var ta=document.getElementById("v7-tb-a"),tb=document.getElementById("v7-tb-b");
      ta.style.background=isB?"transparent":"rgba(99,102,241,.15)";
      ta.style.color=isB?"var(--text-muted,#64748B)":"#c7d2fe";
      ta.style.borderColor=isB?"transparent":"rgba(99,102,241,.30)";
      tb.style.background=isB?"rgba(52,211,153,.12)":"transparent";
      tb.style.color=isB?"#6ee7b7":"var(--text-muted,#64748B)";
      tb.style.borderColor=isB?"rgba(52,211,153,.28)":"transparent";
      document.getElementById("v7-vault").style.display=isB?"flex":"none";
      document.getElementById("v7-tdesc").textContent=isB
        ?"Trúnaðargreining: PDF, Word og Excel. Skjöl eru ekki geymd að lokinni vinnslu."
        :"Fyrir daglega vinnu, almenn skjöl og skýrar niðurstöður á einfaldan hátt.";
      var sb=document.getElementById("v7-sbtn");
      sb.style.background=isB?"#10b981":"var(--accent,#6366F1)";
      var al=document.getElementById("v7-accent-line");
      al.style.background=isB
        ?"linear-gradient(90deg,transparent,rgba(52,211,153,.4),transparent)"
        :"linear-gradient(90deg,transparent,rgba(99,102,241,.4),transparent)";
      v7Clear();
    }}
    window.v7SetTier=v7SetTier;

    function v7ResetBtnColor(){{
      var sb=document.getElementById("v7-sbtn");
      sb.style.background=_t==="b"?"#10b981":"var(--accent,#6366F1)";
    }}
    window.v7ResetBtnColor=v7ResetBtnColor;

    function v7Focus(on){{
      var w=document.getElementById("v7-wrap");
      if(on){{
        if(_t==="b"){{w.style.borderColor="rgba(52,211,153,.40)";w.style.boxShadow="0 0 0 3px rgba(52,211,153,.08),0 8px 24px rgba(0,0,0,.25)";}}
        else{{w.style.borderColor="rgba(99,102,241,.45)";w.style.boxShadow="0 0 0 3px rgba(99,102,241,.08),0 8px 24px rgba(0,0,0,.25)";}}
      }}else{{w.style.borderColor="var(--border-strong,rgba(148,163,184,.20))";w.style.boxShadow="none";}}
    }}
    window.v7Focus=v7Focus;

    function v7FileSel(f){{
      if(!f)return;
      // E3: Unsupported type (client-side)
      var ext=f.name.toLowerCase().split(".").pop();
      if(!["pdf","docx","xlsx"].includes(ext)){{
        v7Stat(_msg.unsupported,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
        return;
      }}
      // E5: Empty file
      if(f.size===0){{
        v7Stat(_msg.empty_file,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
        return;
      }}
      // E6: Too large (client-side, backend also checks)
      if(f.size>20971520){{
        v7Stat(_msg.too_large,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
        return;
      }}
      _f=f;
      var n=f.name;
      // E17: Long filename — truncate display only
      document.getElementById("v7-fname").textContent=
        n.length>26?n.substring(0,22)+"…"+n.slice(n.lastIndexOf(".")):n;
      document.getElementById("v7-status").style.display="none";
      v7UpdateBtn();
    }}
    window.v7FileSel=v7FileSel;

    // H1: Drag+drop (from Sprint 31)
    function v7DragOver(e){{
      e.preventDefault();
      var w=document.getElementById("v7-wrap");
      if(w){{w.style.borderColor=_t==="b"?"rgba(52,211,153,.6)":"rgba(99,102,241,.6)";}}
    }}
    function v7DragLeave(){{
      var w=document.getElementById("v7-wrap");
      if(w){{w.style.borderColor="var(--border-strong,rgba(148,163,184,.20))";w.style.boxShadow="none";}}
    }}
    function v7Drop(e){{
      e.preventDefault();
      v7DragLeave();
      var items=e.dataTransfer&&e.dataTransfer.items;
      // E16: Folder detection
      if(items&&items.length>0){{
        var entry=items[0].webkitGetAsEntry&&items[0].webkitGetAsEntry();
        if(entry&&entry.isDirectory){{
          v7Stat(_msg.folder_drop,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
          return;
        }}
      }}
      var files=e.dataTransfer&&e.dataTransfer.files;
      if(!files||files.length===0)return;
      // E15: Multi-file — use first only
      if(files.length>1){{
        v7Stat(_msg.multi_file,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
      }}
      v7FileSel(files[0]);
    }}
    window.v7DragOver=v7DragOver;
    window.v7DragLeave=v7DragLeave;
    window.v7Drop=v7Drop;
    // Attach drag handlers
    (function(){{
      var w=document.getElementById("v7-wrap");
      if(w){{
        w.addEventListener("dragover",v7DragOver);
        w.addEventListener("dragleave",v7DragLeave);
        w.addEventListener("drop",v7Drop);
      }}
    }})();

    // E14: Navigate away warning
    window.addEventListener("beforeunload",function(e){{
      if(_busy){{e.preventDefault();e.returnValue=_msg.navigate;return _msg.navigate;}}
    }});

    function v7Submit(){{
      // E7: Prevent double-submit
      if(_busy)return;
      var txt=(document.getElementById("v7-txt")||{{}}).value||"";
      // E1+E2: No file and no prompt
      if(!_f&&!txt.trim()){{
        v7Stat(_msg.no_file,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
        return;
      }}
      if(!_f&&txt.trim().length===0){{
        v7Stat(_msg.empty_prompt,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
        return;
      }}
      _busy=true;
      var sbtn=document.getElementById("v7-sbtn");
      sbtn.disabled=true; // E7: disable on first click
      v7Stat("Vinnur úr efninu…","rgba(99,102,241,.07)","var(--accent-light,#818CF8)","rgba(99,102,241,.20)");

      // E8/E13: AbortController with 60s timeout
      var ctrl=new AbortController();
      var _timeoutId=setTimeout(function(){{
        ctrl.abort();
        _busy=false;
        sbtn.disabled=false;
        v7Stat(_msg.timeout,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
      }},60000);

      var fd=new FormData();
      if(_f)fd.append("file",_f);
      if(txt.trim())fd.append("query",txt.trim());

      fetch("/api/analyze-document",{{
        method:"POST",
        body:fd,
        headers:{{"X-Alvitur-Tier":_t==="b"?"vault":"general"}},
        signal:ctrl.signal
      }}).then(function(r){{
        clearTimeout(_timeoutId);
        // E11/E12: Always expect JSON
        return r.json().then(function(d){{return{{status:r.status,data:d}};}}
        ).catch(function(){{return{{status:r.status,data:{{}}}};}}); 
      }}).then(function(res){{
        _busy=false;
        sbtn.disabled=false;
        var s=res.status,d=res.data;
        if(s===200&&d.success){{v7Result(d);return;}}
        // E9/E10: Parse errors
        if(s===422){{
          var em=d.error_code==="no_text_extracted"?_msg.no_text:_msg.parse_fail;
          v7Stat(em,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
          return;
        }}
        if(s===413){{v7Stat(_msg.too_large,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");return;}}
        if(s===415){{v7Stat(_msg.magic_bytes,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");return;}}
        if(s===429){{v7Stat("Of margar beiðnir. Reyndu aftur eftir stund.","rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");return;}}
        if(s===503){{v7Stat(_msg.server,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");return;}}
        // E11: Generic 5xx
        v7Stat(_msg.server,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
      }}).catch(function(err){{
        clearTimeout(_timeoutId);
        _busy=false;
        sbtn.disabled=false;
        // E8: Network error or abort
        if(err&&err.name==="AbortError")return; // timeout handler already fired
        v7Stat(_msg.timeout,"rgba(148,163,184,.05)","var(--text-secondary,#94A3B8)","rgba(148,163,184,.12)");
      }});
    }}
    window.v7Submit=v7Submit;

    function v7Result(d){{
      v7Render(d);
      document.getElementById("v7-status").style.display="none";
      v7UpdateBtn();
    }}

    function v7Stat(msg,bg,col,bc){{
      var el=document.getElementById("v7-status");
      el.style.display="block";el.style.background=bg;
      el.style.color=col;el.style.borderColor=bc||"transparent";
      el.textContent=msg;
    }}

    function v7Clear(){{
      // E19: Full state reset on tier change
      v7Reset();
    }}

    function v7Esc(s){{return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");}}

    function v7Render(d){{
      var h="";
      if(d.summary)h+='<div style="background:var(--bg-elevated,#0F1623);border:1px solid '
        +'var(--border-strong,rgba(148,163,184,.20));border-radius:var(--radius-lg,.75rem);'
        +'padding:.875rem 1rem;margin-top:.75rem;font-size:.8rem;'
        +'color:var(--text-secondary,#94A3B8);line-height:1.75;">'
        +'<div style="font-size:.62rem;color:var(--text-muted,#64748B);text-transform:uppercase;'
        +'letter-spacing:.07em;margin-bottom:.3rem;">Samantekt</div>'+v7Esc(d.summary)+'</div>';
      if(d.citations&&d.citations.length){{
        h+='<div style="font-size:.62rem;color:var(--text-muted,#64748B);text-transform:uppercase;'
          +'letter-spacing:.08em;margin:1rem 0 .45rem;">Heimildir í skjali</div>';
