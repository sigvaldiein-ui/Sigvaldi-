    Aðalfall sem sækir svar við skilaboðum notanda.
    Fasi 1: Mock svör með 1-2 sekúndna töf.

    [FASI-2] UPPFÆRSLA:
    Skipta þessum kóða út:
    ┌──────────────────────────────────────────────────────────┐
    │  # Fjarlægja þessar rowr:                              │
    │  await asyncio.sleep(random.uniform(1.0, 2.0))          │
    │  return velja_mock_svar(skilabus)                       │
    │                                                          │
    │  # Bæta við þessum:                                     │
    │  from core.agent_core_v5 import MimirCoreV5            │
    │  _mimir = MimirCoreV5()  # Einu sinni við ræsingu      │
    │                                                          │
    │  loop = asyncio.get_event_loop()                         │
    │  return await loop.run_in_executor(                      │
    │      None,                                               │
    │      _mimir.process_message,                            │
    │      skilabus,                                           │
    │      int(user_id) if user_id.isdigit() else 0,         │
    │  )                                                       │
    └──────────────────────────────────────────────────────────┘
    """
    # [FASI-1] Mock töf — líkir eftir raunverulegri AI vinnslu
    tof = random.uniform(1.0, 2.0)
    await asyncio.sleep(tof)
    return velja_mock_svar(skilabus)


