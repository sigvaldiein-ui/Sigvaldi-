            status_code=status.HTTP_429_TOO_MANY_REQUESTS,
            detail="Of margar beiðnir. Bíddu smástund og reyndu aftur.",
        )

    # ── Session einangrun: Tryggja að user_id sé aldrei deilt ────────────
    # Í Fasa 1 er user_id 'web_user_fasi1' fyrir alla (mock mode).
    # fá_svar() geymir EKKERT á milli kalla — engin shared state milli notenda.
    # Staðfest: Eina global state er _gæðatak_minni (IP-miðað, lögleg).
    user_id = beidni.user_id or "anonymous"

    logger.info(f"Spjallbeiðni frá {ip} (user_id={user_id!r}): {len(beidni.message)} stafir")

