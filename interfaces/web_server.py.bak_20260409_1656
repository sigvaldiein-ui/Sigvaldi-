SECURE_DOCS_DIR = Path("/workspace/mimir_net/secure_docs")
SECURE_DOCS_DIR.mkdir(parents=True, exist_ok=True)
MAX_PDF_SIZE = 10 * 1024 * 1024  # 10 MB

@app.post("/api/analyze-document")
async def analyze_document(request: Request, file: UploadFile = File(...)):
    """
    Sprint 21 — PDF Analyze Endpoint (Lag 1).
    Tekur við PDF skrá, les texta með PyMuPDF og búr til grófótta greiningu.
    Zero-Data: Skrá er eyð um leið og vinnslu ljúkur.
    """
    import fitz  # PyMuPDF

    # — 1. Staðfesta skrártegund —
    if not file.filename.lower().endswith(".pdf"):
        raise HTTPException(status_code=400, detail="Aðeingis PDF skrár eru leyfar.")

    # — 2. Lesa innihald og staðfesta stærð —
    efni = await file.read()
    if len(efni) > MAX_PDF_SIZE:
        raise HTTPException(status_code=413, detail="PDF of stór (hám. 10 MB).")

    # — 3. Vista tafarbundið í secure_docs/ —
    skra_id = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S_%f")
    skra_slod = SECURE_DOCS_DIR / f"doc_{skra_id}.pdf"

    try:
        skra_slod.write_bytes(efni)

        # — 4. Lesa texta með PyMuPDF —
        texti_hlutar = []
        sidur = 0
        with fitz.open(str(skra_slod)) as doc:
            sidur = len(doc)
            for i, sida in enumerate(doc):
                texti = sida.get_text().strip()
                if texti:
                    texti_hlutar.append(f"[Síða {i+1}]\n{texti}")

        heildartexti = "\n\n".join(texti_hlutar)

    finally:
        # — 5. Zero-Data: Eyða skrá út an nanar —
        if skra_slod.exists():
            skra_slod.unlink()

    if not heildartexti.strip():
        return JSONResponse(content={
            "success": False,
            "error": "Ekki tókst að lesa texta úr PDF (gæti verið skannað mynd).",
            "sidur": sidur,
        })

    # — 6. Skila grunnupplýsingum (LLM greining kemur í Lag 2) —
    # Sprint 24: Citations
    import sys
    sys.path.insert(0, "/workspace/mimir-workspace")
    from sprint23.citations_spec_v1 import CitationExtractor
    extractor = CitationExtractor(efni)
    sidur = len(extractor.doc)
    terms = [w for w in (file.filename or "").replace(".pdf","").split("_") if len(w) > 2]
    if not terms:
        terms = ["skjal"]
    result = extractor.find(query_terms=terms, max_results=3)
    extractor.close()
    import os as _os
    _tier = request.headers.get("X-Alvitur-Tier", "general").lower()
    _summary = None
    if _tier == "general":
        try:
            import httpx as _httpx
            _key = _os.environ.get("OPENROUTER_API_KEY", "")
            _zdr = _os.environ.get("OPENROUTER_ZDR_CONFIRMED", "false") == "true"
            _full = " ".join(extractor._page_texts) if hasattr(extractor, "_page_texts") else ""
            if _key and _zdr and _full:
                _msg = f"Greindu þes skjal stuttlega á íslensku (max 3 setningar):\n{_full[:3000]}"
                _r = _httpx.post("https://openrouter.ai/api/v1/chat/completions",
                    headers={"Authorization": f"Bearer {_key}", "X-No-Cache": "true",
                             "HTTP-Referer": "https://alvitur.is", "X-Title": "Alvitur"},
                    json={"model": "openai/gpt-4o-mini",
                          "messages": [{"role": "user", "content": _msg}],
                          "max_tokens": 300}, timeout=20.0)
                _summary = _r.json()["choices"][0]["message"]["content"]
        except Exception:
            _summary = None
    response = result.to_response_dict()
    response.update({"success": True, "filename": file.filename, "sidur": sidur,
                     "zero_data": True, "tier": _tier, "summary": _summary})
    return JSONResponse(content=response)


